# Copy this file to ~/.config/smartpdf/watch.conf and edit the paths.
# The values below match the BrotherDevice -> Tresorit workflow on this machine.

SMARTPDF_SOURCE_DIR="$HOME/Dropbox/From_BrotherDevice"
SMARTPDF_DEST_DIR="$HOME/Tresorit/Scanned Documents"
SMARTPDF_TRASH_DIR="$HOME/.Thrash"
SMARTPDF_BIN="$HOME/bin/smartpdf"
SMARTPDF_STALE_SECONDS=15

# Local Variables:
# mode: sh
# End:
